# AutoMPDNN-DOA | Figure Recreation Script\
# =========================================\
\
import numpy as np\
import matplotlib.pyplot as plt\
import seaborn as sns\
from mpl_toolkits.mplot3d import Axes3D\
from matplotlib.gridspec import GridSpec\
\
# -----------------------------\
# Global settings\
# -----------------------------\
np.random.seed(42)\
sns.set(style="whitegrid", context="talk")\
plt.rcParams["figure.dpi"] = 140\
plt.rcParams["font.family"] = "DejaVu Sans"\
\
# =========================================\
# Figure 1\
# Narrowband far-field horizontal linear array signal reception model\
# =========================================\
def plot_figure1():\
    fig, ax = plt.subplots(figsize=(12, 4))\
    ax.set_aspect("equal")\
\
    # Array sensors\
    M = 8\
    x = np.arange(M)\
    y = np.zeros(M)\
    ax.scatter(x, y, s=180, color="royalblue", zorder=3)\
\
    for i in range(M):\
        ax.text(x[i], y[i]-0.18, f"S\{i+1\}", ha="center", va="top", fontsize=11)\
\
    # ULA line\
    ax.plot(x, y, color="black", linewidth=2)\
\
    # Incoming wavefront\
    theta = np.deg2rad(35)\
    wave_x = np.linspace(-2, 3, 200)\
    wave_y = np.tan(theta) * (wave_x + 1.5) + 2.0\
    ax.plot(wave_x, wave_y, "--", color="darkorange", linewidth=2, label="Incoming wavefront")\
\
    # Arrow\
    ax.annotate(\
        "", xy=(1.2, 1.2), xytext=(0.2, 2.0),\
        arrowprops=dict(arrowstyle="->", lw=2, color="darkred")\
    )\
    ax.text(1.3, 1.3, r"$\\theta$", fontsize=16, color="darkred")\
\
    # Labels\
    ax.text(3.8, 2.6, "Plane wave", fontsize=12)\
    ax.text(2.2, -0.7, "Uniform Linear Array (ULA)", fontsize=12)\
\
    ax.set_xlim(-2, 8)\
    ax.set_ylim(-1.2, 4)\
    ax.axis("off")\
    plt.title("Figure 1. Narrowband far-field horizontal linear array signal reception model")\
    plt.tight_layout()\
    plt.show()\
\
# =========================================\
# Figure 2\
# MPDNN and MPDNNs architecture\
# =========================================\
def draw_block(ax, xy, w, h, text, fc="#D9EAF7", ec="#2B6CB0"):\
    rect = plt.Rectangle(xy, w, h, facecolor=fc, edgecolor=ec, linewidth=2)\
    ax.add_patch(rect)\
    ax.text(xy[0] + w/2, xy[1] + h/2, text, ha="center", va="center", fontsize=10)\
\
def plot_figure2():\
    fig, ax = plt.subplots(figsize=(14, 6))\
    ax.set_xlim(0, 18)\
    ax.set_ylim(0, 10)\
    ax.axis("off")\
\
    # Input\
    draw_block(ax, (0.8, 4.2), 2.0, 1.4, "Input\\nX(f)\\n(YR_f, YI_f)")\
    # First branch: MPDNN\
    draw_block(ax, (4.0, 6.2), 2.0, 1.2, "Hidden 1")\
    draw_block(ax, (6.6, 6.2), 2.0, 1.2, "Hidden 2")\
    draw_block(ax, (9.2, 6.2), 2.0, 1.2, "Output")\
    ax.text(5.0, 8.0, "MPDNN", ha="center", fontsize=14, fontweight="bold")\
\
    # Second branch: MPDNNs\
    draw_block(ax, (4.0, 2.2), 2.0, 1.2, "Hidden 1")\
    draw_block(ax, (6.6, 2.2), 2.0, 1.2, "Hidden 2")\
    draw_block(ax, (9.2, 2.2), 2.0, 1.2, "Output")\
    ax.text(5.0, 0.4, "MPDNNs", ha="center", fontsize=14, fontweight="bold")\
\
    # Arrows\
    for y in [6.8, 3.0]:\
        ax.annotate("", xy=(4.0, y), xytext=(2.8, 5.0 if y > 5 else 5.0),\
                    arrowprops=dict(arrowstyle="->", lw=2))\
    ax.annotate("", xy=(6.0, 6.8), xytext=(4.0, 6.8), arrowprops=dict(arrowstyle="->", lw=2))\
    ax.annotate("", xy=(8.6, 6.8), xytext=(6.0, 6.8), arrowprops=dict(arrowstyle="->", lw=2))\
    ax.annotate("", xy=(10.4, 6.8), xytext=(8.6, 6.8), arrowprops=dict(arrowstyle="->", lw=2))\
\
    ax.annotate("", xy=(6.0, 3.0), xytext=(4.0, 3.0), arrowprops=dict(arrowstyle="->", lw=2))\
    ax.annotate("", xy=(8.6, 3.0), xytext=(6.0, 3.0), arrowprops=dict(arrowstyle="->", lw=2))\
    ax.annotate("", xy=(10.4, 3.0), xytext=(8.6, 3.0), arrowprops=dict(arrowstyle="->", lw=2))\
\
    ax.text(12.0, 6.8, "Classification / DOA Estimation", fontsize=12, va="center")\
    ax.text(12.0, 3.0, "Classification / DOA Estimation", fontsize=12, va="center")\
\
    plt.title("Figure 2. MPDNN and MPDNNs architecture")\
    plt.tight_layout()\
    plt.show()\
\
# =========================================\
# Figure 3\
# AutoMPDNN training and estimation workflow\
# =========================================\
def plot_figure3():\
    fig, ax = plt.subplots(figsize=(14, 5))\
    ax.set_xlim(0, 18)\
    ax.set_ylim(0, 6)\
    ax.axis("off")\
\
    steps = [\
        (0.5, 2.2, "Signal\\nSimulation"),\
        (3.2, 2.2, "Dataset\\nGeneration"),\
        (5.9, 2.2, "Feature\\nConstruction"),\
        (8.6, 2.2, "MPDNN\\nTraining"),\
        (11.3, 2.2, "Bayesian\\nOptimization"),\
        (14.0, 2.2, "DOA\\nEstimation"),\
    ]\
\
    for x, y, txt in steps:\
        draw_block(ax, (x, y), 2.0, 1.5, txt, fc="#E8F5E9", ec="#2E7D32")\
\
    for i in range(len(steps)-1):\
        x1 = steps[i][0] + 2.0\
        x2 = steps[i+1][0]\
        ax.annotate("", xy=(x2, 3.0), xytext=(x1, 3.0), arrowprops=dict(arrowstyle="->", lw=2))\
\
    ax.text(9.5, 4.7, "AutoMPDNN Training and Inference Pipeline", fontsize=14, fontweight="bold", ha="center")\
    plt.title("Figure 3. AutoMPDNN training and estimation workflow")\
    plt.tight_layout()\
    plt.show()\
\
# =========================================\
# Figure 4\
# Hyperparameter space search results (3D)\
# =========================================\
def plot_figure4():\
    fig = plt.figure(figsize=(10, 7))\
    ax = fig.add_subplot(111, projection="3d")\
\
    l1 = np.linspace(0.0001, 0.01, 20)\
    l2 = np.linspace(0.0001, 0.01, 20)\
    L1, L2 = np.meshgrid(l1, l2)\
\
    # Synthetic validation score surface\
    Z = np.exp(-((L1 - 0.0035)**2 / 0.000006 + (L2 - 0.0065)**2 / 0.000006))\
    Z += 0.15 * np.random.rand(*Z.shape)\
\
    surf = ax.plot_surface(L1, L2, Z, cmap="viridis", alpha=0.85, linewidth=0)\
\
    # Sample points\
    pts_l1 = np.random.uniform(0.0001, 0.01, 50)\
    pts_l2 = np.random.uniform(0.0001, 0.01, 50)\
    pts_z = np.exp(-((pts_l1 - 0.0035)**2 / 0.000006 + (pts_l2 - 0.0065)**2 / 0.000006))\
    pts_z += 0.15 * np.random.rand(50)\
    ax.scatter(pts_l1, pts_l2, pts_z, c="red", s=20)\
\
    ax.set_xlabel("l1")\
    ax.set_ylabel("l2")\
    ax.set_zlabel("Validation Score")\
    ax.set_title("Figure 4. Hyperparameter search space of AutoMPDNN")\
    plt.tight_layout()\
    plt.show()\
\
# =========================================\
# Figure 5\
# Accuracy comparison for activation functions\
# =========================================\
def plot_figure5():\
    activations = ["ReLU", "Sigmoid", "Tanh", "LeakyReLU", "ELU"]\
    accuracy = [98.6, 94.1, 95.2, 97.8, 97.1]\
\
    plt.figure(figsize=(10, 6))\
    bars = plt.bar(activations, accuracy, color=["#2E86C1", "#7D3C98", "#17A589", "#F39C12", "#C0392B"])\
    plt.ylim(90, 100)\
    plt.ylabel("Accuracy (%)")\
    plt.title("Figure 5. Accuracy comparison of different activation functions for num=16")\
    plt.grid(axis="y", linestyle="--", alpha=0.5)\
\
    for b, v in zip(bars, accuracy):\
        plt.text(b.get_x() + b.get_width()/2, v + 0.15, f"\{v:.1f\}%", ha="center", fontsize=11)\
\
    plt.tight_layout()\
    plt.show()\
\
# =========================================\
# Figure 6\
# Comparison of different number of layers and training loss convergence\
# =========================================\
def plot_figure6():\
    epochs = np.arange(1, 101)\
    losses_2 = 0.9 * np.exp(-epochs/28) + 0.05 * np.random.rand(len(epochs))\
    losses_3 = 0.8 * np.exp(-epochs/24) + 0.04 * np.random.rand(len(epochs))\
    losses_4 = 0.7 * np.exp(-epochs/20) + 0.03 * np.random.rand(len(epochs))\
\
    plt.figure(figsize=(11, 6))\
    plt.plot(epochs, losses_2, label="2 Hidden Layers", linewidth=2)\
    plt.plot(epochs, losses_3, label="3 Hidden Layers", linewidth=2)\
    plt.plot(epochs, losses_4, label="4 Hidden Layers", linewidth=2)\
\
    plt.xlabel("Epoch")\
    plt.ylabel("Training Loss")\
    plt.title("Figure 6. Loss convergence for different network depths")\
    plt.legend()\
    plt.grid(True, linestyle="--", alpha=0.5)\
    plt.tight_layout()\
    plt.show()\
\
# =========================================\
# Figure 7\
# Performance comparison for different array sizes\
# =========================================\
def plot_figure7():\
    m = np.array([8, 12, 16, 24, 32])\
    snr10 = np.array([84, 88, 92, 95, 96.5])\
    snr20 = np.array([90, 93.5, 96, 97.8, 98.5])\
\
    plt.figure(figsize=(10, 6))\
    plt.plot(m, snr10, marker="o", linewidth=2.5, label="SNR = 10 dB")\
    plt.plot(m, snr20, marker="s", linewidth=2.5, label="SNR = 20 dB")\
\
    plt.xlabel("Number of Array Elements")\
    plt.ylabel("Accuracy (%)")\
    plt.title("Figure 7. Accuracy vs number of array elements")\
    plt.xticks(m)\
    plt.ylim(80, 100)\
    plt.grid(True, linestyle="--", alpha=0.5)\
    plt.legend()\
    plt.tight_layout()\
    plt.show()\
\
# =========================================\
# Figure 8\
# Comparison with classical and sparse algorithms\
# =========================================\
def plot_figure8():\
    algorithms = [\
        "CBF", "MVDR", "MUSIC", "ESPRIT",\
        "OMP", "ROMP", "l1-SVD", "CNN", "ResNet", "AutoMPDNN"\
    ]\
    speed = [0.98, 0.95, 0.72, 0.80, 0.60, 0.58, 0.40, 0.25, 0.18, 0.90]\
    accuracy = [70, 76, 84, 82, 88, 89, 91, 94, 95, 98.7]\
\
    fig, axes = plt.subplots(2, 1, figsize=(12, 10), sharex=True)\
\
    axes[0].bar(algorithms, speed, color="#3498DB")\
    axes[0].set_ylabel("Relative Speed")\
    axes[0].set_title("Figure 8. Comparison with classical, sparse, and deep learning methods")\
    axes[0].grid(axis="y", linestyle="--", alpha=0.4)\
\
    axes[1].bar(algorithms, accuracy, color="#27AE60")\
    axes[1].set_ylabel("Accuracy (%)")\
    axes[1].set_xlabel("Algorithms")\
    axes[1].grid(axis="y", linestyle="--", alpha=0.4)\
\
    plt.xticks(rotation=35, ha="right")\
    plt.tight_layout()\
    plt.show()\
\
# =========================================\
# Run all figures\
# =========================================\
plot_figure1()\
plot_figure2()\
plot_figure3()\
plot_figure4()\
plot_figure5()\
plot_figure6()\
plot_figure7()\
plot_figure8()\
}