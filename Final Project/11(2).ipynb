  "cells": [\
    \{\
      "cell_type": "markdown",\
      "source": [\
        "# \uc0\u1662 \u1740 \u1575 \u1583 \u1607 \u8204 \u1587 \u1575 \u1586 \u1740  \u1605 \u1602 \u1575 \u1604 \u1607 : AutoMPDNN \u1576 \u1585 \u1575 \u1740  \u1578 \u1582 \u1605 \u1740 \u1606  \u1586 \u1575 \u1608 \u1740 \u1607  \u1608 \u1585 \u1608 \u1583  (DOA)\\n",\
        "**\uc0\u1593 \u1606 \u1608 \u1575 \u1606  \u1605 \u1602 \u1575 \u1604 \u1607 :** An automated multi-layer perceptron discriminative neural network based on Bayesian optimization achieves high-precision one-source single-snapshot direction-of-arrival estimation\\n",\
        "\\n",\
        "**\uc0\u1688 \u1608 \u1585 \u1606 \u1575 \u1604 :** Scientific Reports (2024) | **\u1606 \u1608 \u1740 \u1587 \u1606 \u1583 \u1711 \u1575 \u1606 :** Bin Zhang, et al.\\n",\
        "\\n",\
        "---\\n",\
        "### \uc0\u1777 . \u1605 \u1602 \u1583 \u1605 \u1607  \u1608  \u1670 \u1705 \u1740 \u1583 \u1607 \\n",\
        "\uc0\u1575 \u1740 \u1606  \u1662 \u1585 \u1608 \u1688 \u1607  \u1576 \u1607  \u1662 \u1740 \u1575 \u1583 \u1607 \u8204 \u1587 \u1575 \u1586 \u1740  \u1588 \u1576 \u1705 \u1607  \u1593 \u1589 \u1576 \u1740  AutoMPDNN \u1576 \u1585 \u1575 \u1740  \u1578 \u1582 \u1605 \u1740 \u1606  \u1586 \u1575 \u1608 \u1740 \u1607  \u1608 \u1585 \u1608 \u1583  \u1587 \u1740 \u1711 \u1606 \u1575 \u1604  (DOA) \u1605 \u1740 \u8204 \u1662 \u1585 \u1583 \u1575 \u1586 \u1583 . \u1575 \u1740 \u1606  \u1605 \u1583 \u1604  \u1576 \u1575  \u1578 \u1576 \u1583 \u1740 \u1604  \u1587 \u1740 \u1711 \u1606 \u1575 \u1604 \u8204 \u1607 \u1575 \u1740  \u1606 \u1605 \u1608 \u1606 \u1607 \u8204 \u1576 \u1585 \u1583 \u1575 \u1585 \u1740 \u8204 \u1588 \u1583 \u1607  \u1578 \u1606 \u1705  (Sparse) \u1576 \u1607  \u1581 \u1608 \u1586 \u1607  \u1605 \u1582 \u1578 \u1604 \u1591  (Complex Domain) \u1608  \u1575 \u1587 \u1578 \u1601 \u1575 \u1583 \u1607  \u1575 \u1586  \u1588 \u1576 \u1705 \u1607 \u8204 \u1607 \u1575 \u1740  \u1662 \u1585 \u1587 \u1662 \u1578 \u1585 \u1608 \u1606  \u1670 \u1606 \u1583 \u1604 \u1575 \u1740 \u1607  (MLP) \u1576 \u1607 \u1740 \u1606 \u1607 \u8204 \u1588 \u1583 \u1607  \u1576 \u1575  \u1575 \u1604 \u1711 \u1608 \u1585 \u1740 \u1578 \u1605  \u1576 \u1740 \u1586 \u1740 \u1548  \u1583 \u1602 \u1578  \u1576 \u1575 \u1604 \u1575 \u1740 \u1740  \u1583 \u1585  \u1662 \u1585 \u1583 \u1575 \u1586 \u1588  \u1578 \u1705 \u8204 \u1606 \u1605 \u1608 \u1606 \u1607 \u8204 \u1575 \u1740  (Single-snapshot) \u1575 \u1585 \u1575 \u1574 \u1607  \u1605 \u1740 \u8204 \u1583 \u1607 \u1583 ."\
      ],\
      "metadata": \{\}\
    \},\
    \{\
      "cell_type": "markdown",\
      "source": [\
        "### \uc0\u1778 . \u1605 \u1583 \u1604  \u1585 \u1740 \u1575 \u1590 \u1740  \u1587 \u1740 \u1587 \u1578 \u1605  (System Model)\\n",\
        "\uc0\u1601 \u1585 \u1590  \u1705 \u1606 \u1740 \u1583  \u1740 \u1705  \u1570 \u1585 \u1575 \u1740 \u1607  \u1582 \u1591 \u1740  \u1740 \u1705 \u1606 \u1608 \u1575 \u1582 \u1578  (ULA) \u1576 \u1575  $M$ \u1587 \u1606 \u1587 \u1608 \u1585  \u1583 \u1575 \u1585 \u1740 \u1605  \u1705 \u1607  \u1601 \u1575 \u1589 \u1604 \u1607  \u1576 \u1740 \u1606  \u1587 \u1606 \u1587 \u1608 \u1585 \u1607 \u1575  $d$ \u1575 \u1587 \u1578 . \u1575 \u1711 \u1585  \u1740 \u1705  \u1587 \u1740 \u1711 \u1606 \u1575 \u1604  \u1576 \u1575 \u1606 \u1583  \u1576 \u1575 \u1585 \u1740 \u1705  $s(t)$ \u1575 \u1586  \u1586 \u1575 \u1608 \u1740 \u1607  $\\\\theta$ \u1576 \u1607  \u1570 \u1585 \u1575 \u1740 \u1607  \u1576 \u1585 \u1582 \u1608 \u1585 \u1583  \u1705 \u1606 \u1583 \u1548  \u1576 \u1585 \u1583 \u1575 \u1585  \u1607 \u1583 \u1575 \u1740 \u1578  (Steering Vector) \u1576 \u1607  \u1589 \u1608 \u1585 \u1578  \u1586 \u1740 \u1585  \u1578 \u1593 \u1585 \u1740 \u1601  \u1605 \u1740 \u8204 \u1588 \u1608 \u1583 :\\n",\
        "\\n",\
        "$$ a(\\\\theta) = \\\\left[ 1, e^\{-j 2\\\\pi \\\\frac\{d\}\{\\\\lambda\} \\\\sin(\\\\theta)\}, \\\\dots, e^\{-j 2\\\\pi \\\\frac\{(M-1)d\}\{\\\\lambda\} \\\\sin(\\\\theta)\} \\\\right]^T $$\\n",\
        "\\n",\
        "\uc0\u1587 \u1740 \u1711 \u1606 \u1575 \u1604  \u1583 \u1585 \u1740 \u1575 \u1601 \u1578 \u1740  \u1583 \u1585  \u1570 \u1585 \u1575 \u1740 \u1607  \u1583 \u1585  \u1604 \u1581 \u1592 \u1607  $t$ \u1576 \u1585 \u1575 \u1576 \u1585  \u1575 \u1587 \u1578  \u1576 \u1575 :\\n",\
        "\\n",\
        "$$ x(t) = a(\\\\theta) s(t) + n(t) $$\\n",\
        "\\n",\
        "\uc0\u1705 \u1607  \u1583 \u1585  \u1570 \u1606  $n(t)$ \u1606 \u1608 \u1740 \u1586  \u1587 \u1601 \u1740 \u1583  \u1711 \u1608 \u1587 \u1740  (AWGN) \u1575 \u1587 \u1578 ."\
      ],\
      "metadata": \{\}\
    \},\
    \{\
      "cell_type": "code",\
      "execution_count": null,\
      "source": [\
        "import numpy as np\\n",\
        "import matplotlib.pyplot as plt\\n",\
        "import torch\\n",\
        "import torch.nn as nn\\n",\
        "import torch.optim as optim\\n",\
        "\\n",\
        "# \uc0\u1662 \u1575 \u1585 \u1575 \u1605 \u1578 \u1585 \u1607 \u1575 \u1740  \u1578 \u1608 \u1604 \u1740 \u1583  \u1587 \u1740 \u1711 \u1606 \u1575 \u1604  (ULA)\\n",\
        "M = 8           # \uc0\u1578 \u1593 \u1583 \u1575 \u1583  \u1587 \u1606 \u1587 \u1608 \u1585 \u1607 \u1575 \\n",\
        "d_lambda = 0.5  # \uc0\u1601 \u1575 \u1589 \u1604 \u1607  \u1587 \u1606 \u1587 \u1608 \u1585 \u1607 \u1575  \u1576 \u1607  \u1591 \u1608 \u1604  \u1605 \u1608 \u1580  (d/lambda)\\n",\
        "N = 1000        # \uc0\u1578 \u1593 \u1583 \u1575 \u1583  \u1606 \u1605 \u1608 \u1606 \u1607 \u8204 \u1607 \u1575 \u1740  \u1583 \u1575 \u1583 \u1607 \\n",\
        "\\n",\
        "def generate_doa_data(M, d_lambda, num_samples, snr_db):\\n",\
        "    angles = np.random.uniform(-60, 60, num_samples) # \uc0\u1586 \u1608 \u1575 \u1740 \u1575 \u1740  \u1578 \u1589 \u1575 \u1583 \u1601 \u1740  \u1576 \u1740 \u1606  -60 \u1578 \u1575  60\\n",\
        "    X = np.zeros((num_samples, 2 * M)) # 2*M \uc0\u1576 \u1585 \u1575 \u1740  \u1576 \u1582 \u1588  \u1581 \u1602 \u1740 \u1602 \u1740  \u1608  \u1605 \u1608 \u1607 \u1608 \u1605 \u1740 \\n",\
        "    y = angles\\n",\
        "    \\n",\
        "    for i in range(num_samples):\\n",\
        "        theta = np.deg2rad(angles[i])\\n",\
        "        # \uc0\u1576 \u1585 \u1583 \u1575 \u1585  \u1607 \u1583 \u1575 \u1740 \u1578  (Steering Vector)\\n",\
        "        a_theta = np.exp(-1j * 2 * np.pi * d_lambda * np.arange(M) * np.sin(theta))\\n",\
        "        \\n",\
        "        # \uc0\u1587 \u1740 \u1711 \u1606 \u1575 \u1604  \u1578 \u1705  \u1575 \u1587 \u1606 \u1662 \u8204 \u1588 \u1575 \u1578  \u1576 \u1575  \u1606 \u1608 \u1740 \u1586 \\n",\
        "        s = np.random.randn(1) + 1j * np.random.randn(1)\\n",\
        "        noise_power = 10 ** (-snr_db / 10)\\n",\
        "        noise = np.sqrt(noise_power/2) * (np.random.randn(M) + 1j * np.random.randn(M))\\n",\
        "        \\n",\
        "        x_t = a_theta * s + noise\\n",\
        "        \\n",\
        "        # \uc0\u1580 \u1583 \u1575 \u1587 \u1575 \u1586 \u1740  \u1576 \u1582 \u1588  \u1581 \u1602 \u1740 \u1602 \u1740  \u1608  \u1605 \u1608 \u1607 \u1608 \u1605 \u1740  \u1576 \u1607  \u1593 \u1606 \u1608 \u1575 \u1606  \u1608 \u1585 \u1608 \u1583 \u1740  \u1588 \u1576 \u1705 \u1607 \\n",\
        "        X[i, :M] = np.real(x_t)\\n",\
        "        X[i, M:] = np.imag(x_t)\\n",\
        "        \\n",\
        "    return torch.tensor(X, dtype=torch.float32), torch.tensor(y, dtype=torch.float32)\\n",\
        "\\n",\
        "X_train, y_train = generate_doa_data(M, d_lambda, N, snr_db=10)"\
      ],\
      "outputs": [],\
      "metadata": \{\}\
    \},\
    \{\
      "cell_type": "markdown",\
      "source": [\
        "### \uc0\u1779 . \u1605 \u1593 \u1605 \u1575 \u1585 \u1740  \u1588 \u1576 \u1705 \u1607  AutoMPDNN\\n",\
        "\uc0\u1583 \u1585  \u1575 \u1740 \u1606  \u1576 \u1582 \u1588 \u1548  \u1588 \u1576 \u1705 \u1607  \u1670 \u1606 \u1583 \u1604 \u1575 \u1740 \u1607  (MLP) \u1662 \u1740 \u1588 \u1606 \u1607 \u1575 \u1583  \u1588 \u1583 \u1607  \u1583 \u1585  \u1605 \u1602 \u1575 \u1604 \u1607  \u1662 \u1740 \u1575 \u1583 \u1607 \u8204 \u1587 \u1575 \u1586 \u1740  \u1605 \u1740 \u8204 \u1588 \u1608 \u1583 . \u1588 \u1576 \u1705 \u1607  \u1608 \u1585 \u1608 \u1583 \u1740 \u8204 \u1607 \u1575 \u1740  \u1605 \u1582 \u1578 \u1604 \u1591  (\u1580 \u1583 \u1575  \u1588 \u1583 \u1607  \u1576 \u1607  \u1581 \u1602 \u1740 \u1602 \u1740  \u1608  \u1605 \u1608 \u1607 \u1608 \u1605 \u1740 ) \u1585 \u1575  \u1583 \u1585 \u1740 \u1575 \u1601 \u1578  \u1705 \u1585 \u1583 \u1607  \u1608  \u1705 \u1604 \u1575 \u1587  \u1586 \u1575 \u1608 \u1740 \u1607  (\u1740 \u1575  \u1605 \u1602 \u1583 \u1575 \u1585  \u1662 \u1740 \u1608 \u1587 \u1578 \u1607  \u1586 \u1575 \u1608 \u1740 \u1607 ) \u1585 \u1575  \u1578 \u1582 \u1605 \u1740 \u1606  \u1605 \u1740 \u8204 \u1586 \u1606 \u1583 ."\
      ],\
      "metadata": \{\}\
    \},\
    \{\
      "cell_type": "code",\
      "execution_count": null,\
      "source": [\
        "class AutoMPDNN(nn.Module):\\n",\
        "    def __init__(self, input_size, hidden_layers):\\n",\
        "        super(AutoMPDNN, self).__init__()\\n",\
        "        layers = []\\n",\
        "        in_features = input_size\\n",\
        "        \\n",\
        "        # \uc0\u1587 \u1575 \u1582 \u1578  \u1604 \u1575 \u1740 \u1607 \u8204 \u1607 \u1575 \u1740  \u1662 \u1606 \u1607 \u1575 \u1606  \u1576 \u1585  \u1575 \u1587 \u1575 \u1587  \u1662 \u1740 \u1705 \u1585 \u1576 \u1606 \u1583 \u1740  (\u1605 \u1588 \u1575 \u1576 \u1607  \u1582 \u1585 \u1608 \u1580 \u1740  \u1576 \u1607 \u1740 \u1606 \u1607 \u8204 \u1587 \u1575 \u1586 \u1740  \u1576 \u1740 \u1586 \u1740 )\\n",\
        "        for h in hidden_layers:\\n",\
        "            layers.append(nn.Linear(in_features, h))\\n",\
        "            layers.append(nn.ReLU())\\n",\
        "            layers.append(nn.BatchNorm1d(h))\\n",\
        "            in_features = h\\n",\
        "            \\n",\
        "        # \uc0\u1604 \u1575 \u1740 \u1607  \u1582 \u1585 \u1608 \u1580 \u1740  \u1576 \u1585 \u1575 \u1740  \u1585 \u1711 \u1585 \u1587 \u1740 \u1608 \u1606  \u1586 \u1575 \u1608 \u1740 \u1607  (\u1740 \u1575  Classification \u1583 \u1585  \u1589 \u1608 \u1585 \u1578  \u1711 \u1587 \u1587 \u1578 \u1607 \u8204 \u1587 \u1575 \u1586 \u1740 )\\n",\
        "        layers.append(nn.Linear(in_features, 1))\\n",\
        "        self.network = nn.Sequential(*layers)\\n",\
        "\\n",\
        "    def forward(self, x):\\n",\
        "        return self.network(x)\\n",\
        "\\n",\
        "# \uc0\u1578 \u1593 \u1585 \u1740 \u1601  \u1605 \u1583 \u1604  \u1576 \u1575  3 \u1604 \u1575 \u1740 \u1607  \u1662 \u1606 \u1607 \u1575 \u1606  (\u1576 \u1607  \u1593 \u1606 \u1608 \u1575 \u1606  \u1605 \u1579 \u1575 \u1604 )\\n",\
        "model = AutoMPDNN(input_size=2*M, hidden_layers=[128, 256, 128])\\n",\
        "criterion = nn.MSELoss()\\n",\
        "optimizer = optim.Adam(model.parameters(), lr=0.001)\\n",\
        "\\n",\
        "print(model)"\
      ],\
      "outputs": [],\
      "metadata": \{\}\
    \},\
    \{\
      "cell_type": "markdown",\
      "source": [\
        "### \uc0\u1780 . \u1570 \u1605 \u1608 \u1586 \u1588  \u1605 \u1583 \u1604  \u1608  \u1575 \u1585 \u1586 \u1740 \u1575 \u1576 \u1740  \u1606 \u1578 \u1575 \u1740 \u1580  (Simulation Results)\\n",\
        "\uc0\u1583 \u1585  \u1575 \u1740 \u1606  \u1576 \u1582 \u1588 \u1548  \u1740 \u1705  \u1588 \u1576 \u1740 \u1607 \u8204 \u1587 \u1575 \u1586 \u1740  \u1705 \u1608 \u1578 \u1575 \u1607  \u1575 \u1586  \u1585 \u1608 \u1606 \u1583  \u1570 \u1605 \u1608 \u1586 \u1588  (Loss) \u1608  \u1606 \u1605 \u1608 \u1583 \u1575 \u1585  \u1605 \u1602 \u1575 \u1740 \u1587 \u1607  \u1586 \u1575 \u1608 \u1740 \u1607  \u1578 \u1582 \u1605 \u1740 \u1606  \u1586 \u1583 \u1607  \u1588 \u1583 \u1607  \u1576 \u1575  \u1586 \u1575 \u1608 \u1740 \u1607  \u1608 \u1575 \u1602 \u1593 \u1740  (RMSE) \u1585 \u1587 \u1605  \u1605 \u1740 \u8204 \u1588 \u1608 \u1583 ."\
      ],\
      "metadata": \{\}\
    \},\
    \{\
      "cell_type": "code",\
      "execution_count": null,\
      "source": [\
        "epochs = 100\\n",\
        "loss_history = []\\n",\
        "\\n",\
        "# \uc0\u1581 \u1604 \u1602 \u1607  \u1570 \u1605 \u1608 \u1586 \u1588 \\n",\
        "for epoch in range(epochs):\\n",\
        "    optimizer.zero_grad()\\n",\
        "    outputs = model(X_train).squeeze()\\n",\
        "    loss = criterion(outputs, y_train)\\n",\
        "    loss.backward()\\n",\
        "    optimizer.step()\\n",\
        "    loss_history.append(loss.item())\\n",\
        "\\n",\
        "# \uc0\u1585 \u1587 \u1605  \u1606 \u1605 \u1608 \u1583 \u1575 \u1585  Loss\\n",\
        "plt.figure(figsize=(12, 5))\\n",\
        "plt.subplot(1, 2, 1)\\n",\
        "plt.plot(loss_history, color='blue', linewidth=2)\\n",\
        "plt.title('Training Loss (MSE)')\\n",\
        "plt.xlabel('Epochs')\\n",\
        "plt.ylabel('Loss')\\n",\
        "plt.grid(True)\\n",\
        "\\n",\
        "# \uc0\u1585 \u1587 \u1605  \u1605 \u1602 \u1575 \u1740 \u1587 \u1607  \u1578 \u1582 \u1605 \u1740 \u1606  \u1608  \u1607 \u1583 \u1601 \\n",\
        "plt.subplot(1, 2, 2)\\n",\
        "with torch.no_grad():\\n",\
        "    y_pred = model(X_train).squeeze().numpy()\\n",\
        "\\n",\
        "plt.scatter(y_train.numpy()[:100], y_pred[:100], alpha=0.6, color='red')\\n",\
        "plt.plot([-60, 60], [-60, 60], 'k--') # \uc0\u1582 \u1591  \u1575 \u1740 \u1583 \u1607  \u1570 \u1604 \\n",\
        "plt.title('True vs Predicted DOA (Degrees)')\\n",\
        "plt.xlabel('True Angle')\\n",\
        "plt.ylabel('Predicted Angle')\\n",\
        "plt.grid(True)\\n",\
        "plt.tight_layout()\\n",\
        "plt.show()\\n"\
      ],\
      "outputs": [],\
      "metadata": \{\}\
    \}\
  ]\
\}\
}